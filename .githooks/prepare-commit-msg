#!/usr/bin/env bash
# Git prepare-commit-msg hook wrapper
# Runs prepare-commit-msg scripts

set -euo pipefail

# Find project root (go up from .githooks directory)
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$HOOK_DIR/.." && pwd)"
cd "$ROOT"

# Run prepare-commit-msg scripts
./scripts/ci/prepare-commit-msg/00-add-branch-name.sh "$@"
