#!/usr/bin/env bash
# Git pre-rebase hook wrapper
# Runs pre-rebase validation scripts

set -euo pipefail

# Find project root (go up from .githooks directory)
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$HOOK_DIR/.." && pwd)"
cd "$ROOT"

# Run pre-rebase scripts
./scripts/ci/pre-rebase/00-protect-main.sh "$@"
