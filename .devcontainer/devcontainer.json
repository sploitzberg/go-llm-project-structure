{
  "name": "Go LLM Project Structure",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "eamodio.gitlens"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.goroot": "/usr/local/go",
        "go.gopath": "/home/vscode/go"
      }
    }
  },
  // Mount Windsurf config to persist chat history between host and container
  "mounts": [
    "source=${localEnv:HOME}/.config/Windsurf,target=/home/vscode/.config/Windsurf,type=bind"
  ],
  // Use 'forwardPorts' to make a list of ports inside the container available locally
  "forwardPorts": [
    6060
  ],
  // Use 'postCreateCommand' to run commands after the container is created
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  // Comment out to connect as root instead
  "remoteUser": "vscode"
}